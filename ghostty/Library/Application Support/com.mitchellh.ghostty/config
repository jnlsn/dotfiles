window-padding-x = 8
window-padding-y = 4

cursor-style = block

theme = Birds of Paradise

# Send Alt modifier for Option key presses so zellij (and other terminal
# programs) receive Option+Arrow, Option+hjkl, etc. Only Left Option is
# remapped, so Right Option still types macOS special characters (∆, ˚, ¬).
macos-option-as-alt = left

keybind = shift+enter=text:\x1b\r

# Override Ghostty's default alt+arrow = readline word-nav (ESC b / ESC f).
# Those defaults fire before normal key encoding, so zellij would decode
# Option+Right as Alt+f (ToggleFloatingPanes) instead of Alt+Right (MoveFocus).
# Send explicit CSI modifier-3 sequences so zellij gets real Alt+Arrow.
keybind = alt+left=csi:1;3D
keybind = alt+right=csi:1;3C
keybind = alt+up=csi:1;3A
keybind = alt+down=csi:1;3B
