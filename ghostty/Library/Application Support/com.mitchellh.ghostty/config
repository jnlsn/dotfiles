window-padding-x = 8
window-padding-y = 4

cursor-style = block

theme = Birds of Paradise

# Send Alt modifier for Option key presses so zellij (and other terminal
# programs) receive Option+Arrow, Option+hjkl, etc. Only Left Option is
# remapped, so Right Option still types macOS special characters (∆, ˚, ¬).
macos-option-as-alt = left

keybind = shift+enter=text:\x1b\r
